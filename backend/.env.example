DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/mini_ats

# LLM provider: gemini | openai
LLM_PROVIDER=gemini

OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.0-flash-lite

STORAGE_MODE=local
UPLOAD_DIR=./uploads
PUBLIC_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000

# SMTP for stage automation emails
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=no-reply@mini-ats.local

# Optional: used to sign webhook payloads
WEBHOOK_SIGNING_SECRET=
AUTH_JWT_SECRET=change-me
AUTH_JWT_EXP_HOURS=72
AUTH_COOKIE_NAME=miniats_session
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
GOOGLE_ALLOWED_DOMAIN=
AUTH_ALLOW_DEV_HEADERS=false
AUTH_BOOTSTRAP_ADMIN_EMAIL=

MATCHING_ENABLE_EMBEDDINGS=false
MATCHING_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

PARSE_USE_AI=true
PARSE_AI_TIMEOUT_SECONDS=10

# Optional cheaper providers
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b
