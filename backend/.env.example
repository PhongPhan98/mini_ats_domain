DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/mini_ats

# LLM provider: gemini | openai
LLM_PROVIDER=gemini

OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.0-flash-lite

STORAGE_MODE=local
UPLOAD_DIR=./uploads
PUBLIC_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000

# SMTP for stage automation emails
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=no-reply@mini-ats.local

# Optional: used to sign webhook payloads
WEBHOOK_SIGNING_SECRET=
AUTH_JWT_SECRET=change-me
AUTH_JWT_EXP_HOURS=72
AUTH_COOKIE_NAME=miniats_session
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
GOOGLE_ALLOWED_DOMAIN=
