# Backend production env
DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/miniats
CORS_ORIGINS=https://your-frontend.vercel.app

AUTH_ALLOW_DEV_HEADERS=false
AUTH_JWT_SECRET=CHANGE_ME_STRONG_SECRET
AUTH_BOOTSTRAP_ADMIN_EMAIL=admin@yourcompany.com

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-backend-domain/api/auth/google/callback
GOOGLE_ALLOWED_DOMAIN=

PARSE_USE_AI=true
PARSE_AI_TIMEOUT_SECONDS=10
LLM_PROVIDER=gemini
GEMINI_API_KEY=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
